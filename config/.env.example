# ============================================================================
# AW Barbershop — shared environment variable template
# Copy the relevant section into the matching .env / .env.local file.
# NEVER commit real values — keep secrets out of git.
# ============================================================================

# ---- Frontend (frontend/.env.local) ----
# Variables prefixed NEXT_PUBLIC_ are exposed to the browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000
NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:abcdef123456

# ---- Backend (backend/.env) ----
PORT=4000

# Firebase Admin SDK (server-side, keep secret) — used once you wire up Firestore.
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
